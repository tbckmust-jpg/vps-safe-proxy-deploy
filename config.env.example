# Public address. Required unless a later installer step can auto-detect it safely.
PUBLIC_HOST=

# Contact email for ACME certificates.
EMAIL=

# Optional domains.
HY2_DOMAIN=
XHTTP_DOMAIN=
REALITY_SERVER_NAME=www.microsoft.com

# Default public ports.
REALITY_PORT=443
HY2_PORT=8443
XHTTP_HTTPS_PORT=2053

# NAT export mode.
NAT_MODE=false
REALITY_EXTERNAL_PORT=443
HY2_EXTERNAL_PORT=8443
XHTTP_EXTERNAL_PORT=2053
INSTALL_REALITY=true
INSTALL_HY2=true
INSTALL_XHTTP=true
HY2_UDP_MAPPED=false

# Internal-only Xray XHTTP listener.
XHTTP_INTERNAL_HOST=127.0.0.1
XHTTP_INTERNAL_PORT=10085

# Hysteria2 masquerade.
MASQUERADE_MODE=file
MASQUERADE_PROXY_URL=https://example.com

# Runtime paths. Production defaults are set by lib/common.sh.
ROOT_DIR=/root/vps-oneclick
ETC_DIR=/usr/local/etc
LOG_DIR=/var/log/vps-oneclick
CREDENTIALS_FILE=/root/vps-oneclick/credentials.txt
XRAY_CONFIG_FILE=/usr/local/etc/xray/config.json
HY2_CONFIG_FILE=/usr/local/etc/hysteria/hysteria-server.yaml
CADDY_CONFIG_FILE=/etc/caddy/Caddyfile
BACKUP_DIR=/root/vps-oneclick/backups

# Optional install toggles.
ENABLE_BBR=true
ENABLE_FIREWALL=true

# Optional version pins. Keep latest for normal use, or set tags such as v1.8.x.
XRAY_VERSION=latest
HY2_VERSION=latest

# Advanced runtime paths.
BIN_DIR=/usr/local/bin
SYSTEMD_DIR=/etc/systemd/system
SYSCTL_BBR_FILE=/etc/sysctl.d/99-vps-oneclick-bbr.conf
