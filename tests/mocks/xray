#!/usr/bin/env bash
set -euo pipefail

mock_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
mkdir -p "${mock_dir}/tmp"
printf 'xray %s\n' "$*" >>"${mock_dir}/tmp/mock-calls.log"

is_config_test=0
if [[ "${1:-}" == "run" ]]; then
  case " $* " in
    *" -test "*)
      is_config_test=1
      ;;
  esac
elif [[ "${1:-}" == "test" ]]; then
  is_config_test=1
fi

if [[ "${MOCK_XRAY_LEGACY_TEST_UNSUPPORTED:-0}" == "1" && "${1:-}" == "test" ]]; then
  printf 'xray test: unknown command\n' >&2
  exit 2
fi

if [[ "${MOCK_XRAY_RUN_CONFDIR_FAIL:-0}" == "1" && "${1:-}" == "run" ]]; then
  case " $* " in
    *" -test "*" -confdir "*)
      exit 1
      ;;
  esac
fi

if [[ "${MOCK_XRAY_RUN_CONFIG_FAIL:-0}" == "1" && "${1:-}" == "run" ]]; then
  case " $* " in
    *" -test "*" -config "*)
      exit 1
      ;;
  esac
fi

if [[ "${MOCK_XRAY_RUN_SHORT_CONFIG_FAIL:-0}" == "1" && "${1:-}" == "run" ]]; then
  case " $* " in
    *" -test "*" -c "*)
      exit 1
      ;;
  esac
fi

if [[ "${MOCK_XRAY_TEST_FAIL:-0}" == "1" && "$is_config_test" == "1" ]]; then
  exit 1
fi

if [[ "${1:-}" == "x25519" ]]; then
  case "${MOCK_XRAY_X25519_FORMAT:-password}" in
    publickey)
      printf 'PrivateKey: MOCK_PRIVATE_KEY\n'
      printf 'PublicKey: MOCK_PUBLIC_KEY\n'
      ;;
    old)
      printf 'Private key: MOCK_PRIVATE_KEY\n'
      printf 'Public key: MOCK_PUBLIC_KEY\n'
      ;;
    broken)
      printf 'PrivateKey: SHOULD_NOT_LEAK_PRIVATE\n'
      printf 'Hash32: SHOULD_NOT_LEAK_HASH\n'
      ;;
    *)
      printf 'PrivateKey: MOCK_PRIVATE_KEY\n'
      printf 'Password (PublicKey): MOCK_PUBLIC_KEY\n'
      printf 'Hash32: MOCK_HASH32\n'
      ;;
  esac
fi

exit 0
