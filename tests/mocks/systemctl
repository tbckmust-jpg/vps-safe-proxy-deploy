#!/usr/bin/env bash
set -euo pipefail

mock_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
mkdir -p "${mock_dir}/tmp"
printf 'systemctl %s\n' "$*" >>"${mock_dir}/tmp/mock-calls.log"

if [[ -n "${MOCK_SYSTEMCTL_FAIL_SERVICE:-}" ]]; then
  case " $* " in
    *" restart ${MOCK_SYSTEMCTL_FAIL_SERVICE}"*)
      exit 1
      ;;
  esac
fi

if [[ -n "${MOCK_SYSTEMCTL_INACTIVE_SERVICE:-}" ]]; then
  case " $* " in
    *" is-active --quiet ${MOCK_SYSTEMCTL_INACTIVE_SERVICE}"*)
      exit 3
      ;;
  esac
fi

if [[ "${MOCK_SYSTEMCTL_FAIL:-0}" == "1" ]]; then
  case " $* " in
    *" restart "* | *" disable --now "*)
      exit 1
      ;;
  esac
fi

exit 0
