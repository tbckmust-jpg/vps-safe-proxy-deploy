#!/usr/bin/env bash
set -euo pipefail

mock_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
mkdir -p "${mock_dir}/tmp"
printf 'curl %s\n' "$*" >>"${mock_dir}/tmp/mock-calls.log"

if [[ "${MOCK_PUBLIC_HOST_FAIL:-0}" == "1" ]]; then
  exit 22
fi

case "$*" in
*"api.ipify.org"* | *"ifconfig.co"* | *"icanhazip.com"*)
  printf '%s\n' "${MOCK_PUBLIC_HOST_VALUE:-203.0.113.10}"
  ;;
*)
  printf '%s\n' "mock curl output"
  ;;
esac
